// types/chargingStation.ts
interface ChargingStation {
  id: string;
  name: string;
  location: {
    latitude: number;
    longitude: number;
  };
  available: boolean;
  chargingType: string[];
  powerOutput: number;
  pricePerKwh: number;
  rating: number;
  reviews: number;
}

// services/chargingStations.ts
import firestore from '@react-native-firebase/firestore';
import { GOOGLE_MAPS_API_KEY } from '@env';

export class ChargingStationService {
  private stationsRef = firestore().collection('charging_stations');

  public async getNearbyStations(
    latitude: number,
    longitude: number,
    radius: number
  ): Promise<ChargingStation[]> {
    const geopoint = new firebase.firestore.GeoPoint(latitude, longitude);
    
    try {
      const snapshot = await this.stationsRef
        .where('location', '>=', geopoint)
        .limit(20)
        .get();
        
      return snapshot.docs
        .map(doc => ({ id: doc.id, ...doc.data() } as ChargingStation))
        .filter(station => this.isWithinRadius(
          station.location,
          { latitude, longitude },
          radius
        ));
    } catch (error) {
      throw new Error(`Failed to fetch charging stations: ${error.message}`);
    }
  }

  private isWithinRadius(
    point1: { latitude: number; longitude: number },
    point2: { latitude: number; longitude: number },
    radius: number
  ): boolean {
    const R = 6371; // Earth's radius in kilometers
    const lat1 = this.toRadian(point1.latitude);
    const lon1 = this.toRadian(point1.longitude);
    const lat2 = this.toRadian(point2.latitude);
    const lon2 = this.toRadian(point2.longitude);

    const dLat = lat2 - lat1;
    const dLon = lon2 - lon1;

    const a = Math.sin(dLat/2) * Math.sin(dLat/2) +
              Math.cos(lat1) * Math.cos(lat2) *
              Math.sin(dLon/2) * Math.sin(dLon/2);
    
    const c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1-a));
    const distance = R * c;

    return distance <= radius;
  }

  private toRadian(degree: number): number {
    return degree * Math.PI / 180;
  }
}

// components/ChargingStationLocator.tsx
import React, { useState, useEffect } from 'react';
import { View, Text, StyleSheet } from 'react-native';
import MapView, { Marker, Callout } from 'react-native-maps';
import Geolocation from '@react-native-community/geolocation';
import { ChargingStationService } from '../services/chargingStations';

const ChargingStationLocator: React.FC = () => {
  const [region, setRegion] = useState({
    latitude: 0,
    longitude: 0,
    latitudeDelta: 0.0922,
    longitudeDelta: 0.0421,
  });
  const [stations, setStations] = useState<ChargingStation[]>([]);
  const [loading, setLoading] = useState(true);
  const stationService = new ChargingStationService();

  useEffect(() => {
    getCurrentLocation();
  }, []);

  const getCurrentLocation = () => {
    Geolocation.getCurrentPosition(
      position => {
        const { latitude, longitude } = position.coords;
        setRegion(prev => ({
          ...prev,
          latitude,
          longitude
        }));
        fetchNearbyStations(latitude, longitude);
      },
      error => console.error(error),
      { enableHighAccuracy: true, timeout: 15000, maximumAge: 10000 }
    );
  };

  const fetchNearbyStations = async (latitude: number, longitude: number) => {
    try {
      const nearbyStations = await stationService.getNearbyStations(
        latitude,
        longitude,
        10 // 10km radius
      );
      setStations(nearbyStations);
    } catch (error) {
      console.error(error);
    } finally {
      setLoading(false);
    }
  };

  return (
    <View style={styles.container}>
      <MapView
        style={styles.map}
        region={region}
        onRegionChangeComplete={setRegion}
      >
        {stations.map(station => (
          <Marker
            key={station.id}
            coordinate={station.location}
            pinColor={station.available ? 'green' : 'red'}
          >
            <Callout>
              <View style={styles.callout}>
                <Text style={styles.stationName}>{station.name}</Text>
                <Text>Power: {station.powerOutput}kW</Text>
                <Text>Price: ${station.pricePerKwh}/kWh</Text>
                <Text>Rating: {station.rating} ⭐️ ({station.reviews})</Text>
                <Text style={styles.availability}>
                  {station.available ? 'Available' : 'Occupied'}
                </Text>
              </View>
            </Callout>
          </Marker>
        ))}
      </MapView>
    </View>
  );
};

const styles = StyleSheet.create({
  container: {
    flex: 1,
  },
  map: {
    flex: 1,
  },
  callout: {
    width: 200,
    padding: 10,
  },
  stationName: {
    fontWeight: 'bold',
    fontSize: 16,
    marginBottom: 5,
  },
  availability: {
    marginTop: 5,
    fontWeight: '500',
  },
});
